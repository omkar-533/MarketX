# Supabase (auth + journal sync)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Live market data — Fyers API ONLY (no Yahoo / NSE / external stock APIs)
VITE_MARKET_LIVE=true

# Fyers API v3 — quotes, OHLC, option chain, WebSocket (required for live site)
# Real-time: React → Socket.IO (/socket.io) → Node → Fyers WebSocket
# Create app: https://myapi.fyers.in/dashboard/
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_REDIRECT_URI=http://127.0.0.1:5000/api/fyers/callback
# Optional: paste access token after OAuth, or connect from Profile → Fyers
FYERS_ACCESS_TOKEN=
# Market provider is always Fyers when token is set
MARKET_PROVIDER=fyers

# Paper trading uses real LTP for watchlist + order fills (requires npm run server)
VITE_PAPER_TRADING_LIVE=true

# Optional: broker OHLC if you have your own backend
# VITE_BROKER_CHART_API=https://your-broker-api.com

# Master AI — OpenRouter (multi-model GPT, Claude, Gemini, Llama, DeepSeek, Sonar web)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here
