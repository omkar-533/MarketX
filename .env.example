# ============ Frontend (Vercel) — public ============
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_MARKET_LIVE=true
VITE_PAPER_TRADING_LIVE=true

# Production: Render API URL (required on Vercel)
VITE_API_URL=https://your-api.onrender.com
VITE_WS_URL=https://your-api.onrender.com

# Dev only (optional)
# VITE_DEV_URL=http://localhost:5173

# ============ Backend (Render) — secret ============
NODE_ENV=development
PORT=5000
JWT_SECRET=change-me-to-long-random-string

# Fyers API v3 — https://myapi.fyers.in/dashboard/
FYERS_APP_ID=your-app-id-100
# Alias supported:
# FYERS_CLIENT_ID=your-app-id-100
FYERS_SECRET_KEY=your-secret-key

# OAuth redirect — must match Fyers dashboard EXACTLY
# Local (frontend capture):
# FYERS_REDIRECT_URI=http://localhost:5173/fyers-login
# Production (server callback):
# FYERS_REDIRECT_URI=https://your-api.onrender.com/api/auth/fyers/callback

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
API_PUBLIC_URL=http://127.0.0.1:5000

# Optional: paste token after OAuth (skip if using OAuth flow)
# FYERS_ACCESS_TOKEN=

MARKET_PROVIDER=fyers
OPENROUTER_API_KEY=sk-or-your-key-here
