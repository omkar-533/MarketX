# Render Production Environment Variables
# Copy these to Render Dashboard → Settings → Environment

# === Node Environment ===
NODE_ENV=production
PORT=10000

# === Fyers API Configuration ===
# Get these from https://www.fyers.in (Developer Settings)
FYERS_APP_ID=UYCSJH0UIQ-100
FYERS_SECRET_KEY=O2KU1I29DR
FYERS_REDIRECT_URI=https://your-frontend-vercel-url.vercel.app/fyers-login

# === URLs ===
# Update these to your actual deployed URLs
FRONTEND_URL=https://your-frontend-vercel-url.vercel.app
API_PUBLIC_URL=https://your-backend-render-url.onrender.com

# === CORS Configuration ===
CORS_ORIGINS=https://your-frontend-vercel-url.vercel.app,http://localhost:5173

# === Session Configuration ===
JWT_SECRET=your-secret-key-change-in-production
COOKIE_SECURE=true

# === Market Data Provider ===
MARKET_PROVIDER=fyers
MARKET_LIVE=true

# === Fyers Access Token (Auto-Connect) ===
# After first successful login locally:
# 1. Run: node scripts/extract-fyers-token.mjs
# 2. Copy the token and paste here
# 3. Backend will auto-connect on boot without requiring manual login
FYERS_ACCESS_TOKEN=your-token-here
# Optional but recommended for zero-manual renew:
# FYERS_REFRESH_TOKEN=your-refresh-token
# FYERS_PIN=1234

# === Optional: AI Services ===
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# === Optional: Supabase (for token persistence) ===
# Uncomment if using Supabase token storage instead of env var
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# === Logging & Debugging ===
LOG_LEVEL=info

# === Rate Limiting (if needed) ===
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
